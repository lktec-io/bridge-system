# ── Server ──────────────────────────────────────────────────
PORT=8005
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=bridge

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ── CORS / Client ─────────────────────────────────────────────
# Production: your domain. Development: http://localhost:5789
CLIENT_URL=http://localhost:5789

# ── File uploads ──────────────────────────────────────────────
# local  → saves to server/uploads/
# cloudinary → uploads to Cloudinary CDN
UPLOAD_MODE=local
SERVER_URL=http://localhost:8005

# ── Cloudinary (only when UPLOAD_MODE=cloudinary) ─────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
